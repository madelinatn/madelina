{
  "name": "yucca-cafe",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build && node -e \"const fs=require('fs'); fs.copyFileSync('dist/index.html','dist/404.html'); ['menu','franchise','admin','admin-login','admin-franchise'].forEach(p => { fs.mkdirSync('dist/'+p,{recursive:true}); fs.copyFileSync('dist/index.html','dist/'+p+'/index.html'); });\"",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260516.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "terser": "^5.48.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wrangler": "^4.100.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.27.3": true,
    "workerd@1.20260611.1": true
  }
}
